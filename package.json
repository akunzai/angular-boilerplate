{
  "name": "angular-boilerplate",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --watch=false --coverage",
    "lint": "ng lint",
    "i18n:extract": "ngx-translate-extract -i ./src -o ./src/locales/{en,zh-Hant}.json --null-as-default-value --sort --clean",
    "msw": "pnpm dlx msw init"
  },
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@ngx-translate/core": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@biesbjerg/ngx-translate-extract": "^7.0.4",
    "@eslint/js": "^10.0.1",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "msw": "^2.14.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "web-streams-polyfill": "^4.2.0"
  },
  "msw": {
    "workerDirectory": [
      "src"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "msw",
      "unrs-resolver"
    ],
    "overrides": {
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "vite@>=7.0.0 <7.3.2": ">=7.3.2"
    }
  }
}
